# Safe local defaults only. Copy to .env; never commit integration credentials.
BRP_DATABASE_URL=postgresql+psycopg://brp:brp@localhost:55432/brp
BRP_PSQL_URL=postgresql://brp:brp@localhost:55432/brp
BRP_API_PORT=8100
# Explicitly local only. Leave false/absent in every shared or production environment.
BRP_LOCAL_DEVELOPMENT_HEADERS=false
# Production OIDC settings are required together; RS256 is the fixed default allowlist.
BRP_OIDC_ISSUER=
BRP_OIDC_AUDIENCE=
BRP_OIDC_JWKS_URL=
BRP_OIDC_ALGORITHMS=RS256
BRP_OIDC_ROLES_CLAIM=roles
BRP_LLM_PROVIDER=mock
BRP_LLM_BULK_MODEL=
BRP_LLM_FRONTIER_MODEL=
BRP_LLM_API_KEY=
BRP_LLM_BASE_URL=
BRP_LLM_LIVE=0
JOERN_MODE=docker
JOERN_HOME=
PYTHONUTF8=1
JAVA_TOOL_OPTIONS=-Dfile.encoding=UTF-8
