# Safe local defaults only. Copy to .env; never commit integration credentials.
BRP_DATABASE_URL=postgresql+psycopg://brp:brp@localhost:55432/brp
BRP_PSQL_URL=postgresql://brp:brp@localhost:55432/brp
# Shared RDS runtime uses the same keys with a URL-encoded password, database `brp`, and
# `sslmode=require`. Keep real cloud URLs only in the ignored `.env` file.
BRP_API_PORT=8100
# Explicitly local only. Leave false/absent in every shared or production environment.
BRP_LOCAL_DEVELOPMENT_HEADERS=false
# Production OIDC settings are required together; RS256 is the fixed default allowlist.
BRP_OIDC_ISSUER=
BRP_OIDC_AUDIENCE=
BRP_OIDC_JWKS_URL=
BRP_OIDC_ALGORITHMS=RS256
BRP_OIDC_ROLES_CLAIM=roles
# Public Java evidence-agent imports remain disabled until live mode and a key are set.
# Small-flow default: Groq's OpenAI-compatible free tier with best-effort JSON Schema.
BRP_LLM_PROVIDER=groq
BRP_LLM_MODEL=openai/gpt-oss-120b
GROQ_API_KEY=
# Generic providers may instead use BRP_LLM_API_KEY/BRP_LLM_BASE_URL and
# BRP_LLM_RESPONSE_FORMAT=json_object|json_schema.
BRP_LLM_API_KEY=
BRP_LLM_BASE_URL=
BRP_LLM_RESPONSE_FORMAT=json_object
BRP_LLM_MAX_ATTEMPTS=1
BRP_LLM_LIVE=false
BRP_DATABASE_CONNECT_TIMEOUT_SECONDS=5
# Optional heavy escalation only; not used by the active small-repository flow.
# JOERN_HOME=
PYTHONUTF8=1
JAVA_TOOL_OPTIONS=-Dfile.encoding=UTF-8
